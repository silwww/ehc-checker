# Anthropic API key (get from https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Shared team password for accessing EHC Checker (single value, all 4 OVs use it)
# To rotate: change this value and redeploy. All existing sessions become invalid.
EHC_SHARED_SECRET=your-shared-team-password-here

# Server-side secret used to sign session cookies (any random 32+ char string)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EHC_COOKIE_SECRET=your-random-cookie-signing-secret-here

# Model to use (claude-sonnet-4-5 recommended)
CLAUDE_MODEL=claude-sonnet-4-5
