{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EHC Checker Rule Set Registry Schema",
  "description": "Schema for rules/_registry.json. Defines the structure of a rule set entry.",
  "type": "object",
  "properties": {
    "description": { "type": "string" },
    "ruleSets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "version", "path", "ruleSetFile", "certificateTypes", "enabled"],
        "properties": {
          "id": { "type": "string", "description": "Unique identifier, format: commodity-origin-destination" },
          "name": { "type": "string" },
          "version": { "type": "string" },
          "versionDate": { "type": "string", "format": "date" },
          "author": { "type": "string" },
          "commodity": { "type": "string" },
          "origin": { "type": "string" },
          "destination": { "type": "string" },
          "path": { "type": "string", "description": "Path to the rule set folder relative to project root" },
          "ruleSetFile": { "type": "string", "description": "Rule set markdown filename inside the rule set folder" },
          "librariesPath": { "type": "string", "description": "Per-rule-set libraries folder relative to path" },
          "sharedLibrariesPath": { "type": "string", "description": "Shared libraries folder relative to project root" },
          "certificateTypes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code", "name", "detection"],
              "properties": {
                "code": { "type": "string" },
                "name": { "type": "string" },
                "description": { "type": "string" },
                "relevantParts": { "type": "array", "items": { "type": "string" } },
                "detection": {
                  "type": "object",
                  "properties": {
                    "footerPatterns": { "type": "array", "items": { "type": "string" } },
                    "headerKeywords": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          },
          "notes": { "type": "string" },
          "enabled": { "type": "boolean" }
        }
      }
    }
  }
}
